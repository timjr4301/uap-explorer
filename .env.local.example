# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains your secret keys.

# ── Supabase ──────────────────────────────────────────────
# Found in: supabase.com → your project → Project Settings → API

# Public (safe to expose in browser code)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Secret (only used by scripts running on YOUR computer, not the website)
# Never put this in any Next.js app/ file — it bypasses row-level security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
